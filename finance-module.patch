+}
+
+// ══════════════════════════════════════════
+// Cash Flow Group (collapsible)
+// ══════════════════════════════════════════
+
+function CashFlowGroup({ group, expanded, onToggle }) {
+  const total = (group.months || []).reduce((s, v) => s + (v || 0), 0);
+
+  return (
+    <>
+      <tr
+        onClick={onToggle}
+        className="border-b border-slate-100 cursor-pointer hover:bg-slate-50 font-medium"
+      >
